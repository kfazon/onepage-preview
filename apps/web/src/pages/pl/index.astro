---
const title = 'Peek — Darmowe podglądy jednej strony dla firm';
const stats = [
  { value: '60 sek.', label: 'do odebrania podglądu' },
  { value: '1 strona', label: 'zoptymalizowana pod kątem konwersji mobilnej' },
  { value: '0 zł', label: 'za pierwszy podgląd' }
];

const steps = [
  {
    title: 'Znajdujemy publiczne dane o firmie',
    body: 'Nazwa, godziny otwarcia, lokalizacja, zdjęcia i dane kontaktowe z publicznych źródeł — nigdy dane prywatne.'
  },
  {
    title: 'Generujemy profesjonalny podgląd',
    body: 'Czysta strona z hero, usługami, mapą, społecznym dowodem słuszności i wyraźnym CTA kontaktowym.'
  },
  {
    title: 'Odbierasz, edytujesz lub publikujesz',
    body: 'Najpierw zobacz darmowy podgląd, potem połącz własną domenę lub opublikuj z hostingiem i wsparciem.'
  }
];

const templates = [
  {
    name: 'Launch Teaser',
    useCase: 'Nowe firmy, konsultanci, małe marki',
    features: ['Hero + CTA', 'Grid korzyści', 'Social proof', 'Sticky CTA']
  },
  {
    name: 'Product Spotlight',
    useCase: 'Strony ofertowe dla usług i pakietów',
    features: ['Grid funkcji', 'Sekcja porównawcza', 'FAQ', 'Pozyskiwanie leadów']
  },
  {
    name: 'Event Waitlist',
    useCase: 'Wydarzenia, warsztaty, otwarcia, pop-upy',
    features: ['Agenda', 'Karty prelegentów', 'Mapa', 'Formularz listy oczekujących']
  }
];

const pricing = [
  {
    tier: 'Preview',
    price: '0 zł',
    description: 'Bezpłatny podgląd jako proof of value',
    points: ['URL podglądu', 'Dane firmy + CTA', '1 korekta', 'Rezygnacja w każdej chwili']
  },
  {
    tier: 'Go Live',
    price: '59 zł/msc',
    description: 'Najprostsza droga do prawdziwej strony',
    points: ['Własna domena', 'Bez brandu podglądu', 'Analytics', 'Zarządzany formularz kontaktowy']
  },
  {
    tier: 'Growth',
    price: '119 zł/msc',
    description: 'Dla firm potrzebujących większej widoczności',
    points: ['Podstawy SEO', 'Synchronizacja z Google Business', 'Linki społecznościowe', 'Priorytetowe zmiany']
  }
];
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Peek automatycznie generuje podglądy jednej strony dla firm bez strony internetowej. Najpierw zobacz za darmo, potem odbierz i publikuj." />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Peek — Darmowe podglądy jednej strony dla firm" />
    <meta property="og:description" content="Peek automatycznie generuje podglądy jednej strony dla firm bez strony internetowej. Najpierw zobacz za darmo, potem odbierz i publikuj." />
    <meta property="og:url" content="https://peek-preview.pages.dev/pl/" />
    <meta property="og:image" content="https://peek-preview.pages.dev/og-default.png" />
    <meta property="og:site_name" content="Peek" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Peek — Darmowe podglądy jednej strony dla firm" />
    <meta name="twitter:description" content="Peek automatycznie generuje podglądy jednej strony dla firm bez strony internetowej. Najpierw zobacz za darmo, potem odbierz i publikuj." />
    <meta name="twitter:image" content="https://peek-preview.pages.dev/og-default.png" />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0b1020;
        --panel: rgba(16, 24, 48, 0.8);
        --panel-strong: #121a33;
        --text: #eef2ff;
        --muted: #a6b0cf;
        --line: rgba(255,255,255,0.1);
        --accent: #7c9cff;
        --accent-2: #67e8f9;
        --success: #86efac;
        --shadow: 0 20px 60px rgba(0,0,0,0.35);
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: radial-gradient(circle at top, rgba(124,156,255,0.18), transparent 25%), radial-gradient(circle at right, rgba(103,232,249,0.12), transparent 20%), var(--bg);
        color: var(--text);
      }
      a { color: inherit; text-decoration: none; }
      .container { width: min(1120px, calc(100% - 32px)); margin: 0 auto; }
      .nav { position: sticky; top: 0; backdrop-filter: blur(16px); background: rgba(11,16,32,0.7); border-bottom: 1px solid var(--line); z-index: 10; }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 16px 0; gap: 16px; }
      .brand { font-weight: 800; letter-spacing: 0.02em; }
      .brand span { color: var(--accent-2); }
      .nav-links { display: flex; gap: 18px; color: var(--muted); font-size: 0.95rem; }
      .btn { display: inline-flex; align-items: center; justify-content: center; padding: 14px 20px; border-radius: 999px; border: 1px solid transparent; font-weight: 700; transition: 180ms ease; }
      .btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent-2)); color: #07111f; box-shadow: var(--shadow); }
      .btn-primary:hover { transform: translateY(-1px); }
      .btn-secondary { border-color: var(--line); background: rgba(255,255,255,0.02); }
      .hero { padding: 72px 0 40px; display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 32px; align-items: center; }
      .eyebrow { display: inline-flex; gap: 8px; align-items: center; padding: 8px 12px; border: 1px solid rgba(134,239,172,0.25); border-radius: 999px; color: var(--success); background: rgba(134,239,172,0.08); font-size: 0.9rem; margin-bottom: 20px; }
      h1 { margin: 0 0 16px; font-size: clamp(2.6rem, 5vw, 4.8rem); line-height: 0.98; letter-spacing: -0.04em; }
      .hero p { margin: 0 0 28px; color: var(--muted); font-size: 1.1rem; line-height: 1.7; max-width: 62ch; }
      .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 28px; }
      .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
      .stat, .card { background: var(--panel); border: 1px solid var(--line); border-radius: 24px; box-shadow: var(--shadow); }
      .stat { padding: 18px; }
      .stat strong { display: block; font-size: 1.2rem; margin-bottom: 6px; }
      .stat span { color: var(--muted); font-size: 0.92rem; }
      .preview-shell { padding: 18px; }
      .browser-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
      .dot { width: 10px; height: 10px; border-radius: 50%; background: rgba(255,255,255,0.25); }
      .preview-body { border-radius: 20px; background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02)); border: 1px solid rgba(255,255,255,0.08); overflow: hidden; }
      .preview-hero { padding: 22px; background: linear-gradient(135deg, rgba(124,156,255,0.24), rgba(103,232,249,0.14)); }
      .preview-hero small { color: var(--muted); }
      .preview-hero h3 { margin: 8px 0; font-size: 1.6rem; }
      .preview-hero p { margin: 0; color: #dce4ff; }
      .preview-grid { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 12px; padding: 16px; }
      .mini-card { padding: 14px; border-radius: 16px; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); }
      section { padding: 36px 0; }
      .section-head { margin-bottom: 20px; }
      .section-head h2 { margin: 0 0 8px; font-size: clamp(1.8rem, 3vw, 2.6rem); }
      .section-head p { margin: 0; color: var(--muted); max-width: 70ch; }
      .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
      .grid-3 .card, .grid-pricing .card { padding: 22px; }
      .card h3 { margin: 0 0 10px; }
      .card p, .card li { color: var(--muted); line-height: 1.65; }
      .card ul { padding-left: 18px; margin: 12px 0 0; }
      .grid-pricing { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
      .price { font-size: 2rem; font-weight: 800; margin: 10px 0; }
      .highlight { position: relative; overflow: hidden; }
      .highlight::after { content: 'Polecane'; position: absolute; top: 14px; right: -44px; background: var(--accent-2); color: #041018; padding: 6px 42px; transform: rotate(35deg); font-size: 0.8rem; font-weight: 800; }
      .banner { padding: 22px; border-radius: 24px; border: 1px solid var(--line); background: linear-gradient(135deg, rgba(124,156,255,0.16), rgba(103,232,249,0.12)); display: flex; align-items: center; justify-content: space-between; gap: 20px; }
      footer { padding: 28px 0 48px; color: var(--muted); font-size: 0.95rem; }
      @media (max-width: 920px) {
        .hero, .preview-grid, .grid-3, .grid-pricing, .stats { grid-template-columns: 1fr; }
        .nav-inner, .banner { flex-direction: column; align-items: flex-start; }
        .nav-links { flex-wrap: wrap; }
      }
    </style>
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="#top">Peek<span>.</span></a>
        <nav class="nav-links">
          <a href="#how-it-works">Jak to działa</a>
          <a href="#templates">Szablony</a>
          <a href="#pricing">Ceny</a>
          <a href="/upgrade">Ulepsz →</a>
          <a href="/refer">Poleć znajomemu</a>
        </nav>
      </div>
    </header>

    <main id="top" class="container">
      <section class="hero">
        <div>
          <div class="eyebrow">Darmowy podgląd • Stworzony z publicznych danych firmy • Odbierz w 60 sekund</div>
          <h1>Budujemy pierwszą wersję Twojej strony internetowej zanim nas zatrudnisz.</h1>
          <p>
            Peek automatycznie generuje podglądy jednej strony dla firm, które wciąż polegają na Instagramie,
            Google Maps lub poczcie pantoflowej. Najpierw zobacz stronę, potem zdecyduj: odbierz, edytuj lub publikuj.
          </p>
          <div class="cta-row">
            <a class="btn btn-primary" href="#pricing">Zobacz ceny</a>
            <a class="btn btn-secondary" href="#templates">Zobacz szablony</a>
          </div>
          <div class="stats">
            {stats.map((item) => (
              <div class="stat">
                <strong>{item.value}</strong>
                <span>{item.label}</span>
              </div>
            ))}
          </div>
        </div>

        <aside class="card preview-shell" aria-label="Przykładowy podgląd">
          <div class="browser-bar">
            <span class="dot"></span><span class="dot"></span><span class="dot"></span>
          </div>
          <div class="preview-body">
            <div class="preview-hero">
              <small>Preview URL • mobilna • szybko się ładuje</small>
              <h3>Kawiarnia Poranek Warszawa</h3>
              <p>Kawa speciality, ciasta domowe, godziny otwarcia i bezpośredni kontakt — wszystko od razu widać.</p>
            </div>
            <div class="preview-grid">
              <div class="mini-card">
                <strong>Co widzą odwiedzający</strong>
                <p>Hero, usługi, mapa, social proof i wyraźne CTA kontaktowe.</p>
              </div>
              <div class="mini-card">
                <strong>Co otrzymuje właściciel</strong>
                <p>Link do odbioru, edytowalna treść i ścieżka rozwoju.</p>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <section id="how-it-works">
        <div class="section-head">
          <h2>Jak działa Peek</h2>
          <p>Proces jest prosty celowo: najpierw tworzymy widoczną wartość, potem przekształcamy odpowiednie firmy w płatny hosting i wsparcie.</p>
        </div>
        <div class="grid-3">
          {steps.map((step, index) => (
            <article class="card">
              <small>Krok {index + 1}</small>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="templates">
        <div class="section-head">
          <h2>System szablonów do szybkiego generowania podglądów</h2>
          <p>Zaczynamy skoncentrowanie: szablony wielokrotnego użytku, które pasują do różnych nisz bez odbudowywania od zera.</p>
        </div>
        <div class="grid-3">
          {templates.map((template) => (
            <article class="card">
              <h3>{template.name}</h3>
              <p><strong>Idealne dla:</strong> {template.useCase}</p>
              <ul>{template.features.map((feature) => <li>{feature}</li>)}</ul>
            </article>
          ))}
        </div>
      </section>

      <section id="pricing">
        <div class="section-head">
          <h2>Prosta ścieżka cenowa</h2>
          <p>Darmowy podgląd jako magnes na leady. Następnie jasny plan Go Live dla prawdziwej domeny, hostingu i wsparcia.</p>
        </div>
        <div class="grid-pricing">
          {pricing.map((plan, index) => (
            <article class:list={["card", index === 1 && "highlight"]}>
              <small>{plan.tier}</small>
              <div class="price">{plan.price}</div>
              <p>{plan.description}</p>
              <ul>{plan.points.map((point) => <li>{point}</li>)}</ul>
            </article>
          ))}
        </div>
      </section>

      <section>
        <div class="banner">
          <div>
            <h2 style="margin:0 0 8px;">Zbudowane dla transparentnego outreachu</h2>
            <p style="margin:0; color:var(--muted); max-width:64ch;">
              Każdy podgląd zawiera wyraźny flow odbioru, opcję rezygnacji i transparentne informacje o wykorzystaniu publicznych danych firmy.
            </p>
          </div>
          <a class="btn btn-primary" href="mailto:hallo@peek.example">Zamów pierwszy test niszy</a>
        </div>
      </section>
    </main>

    <footer class="container">
      Peek • Platforma podglądów jednej strony dla małych firm • Najpierw preview, potem Go Live.
      <span style="display:block; margin-top:12px; font-size:0.8rem;"><a href="/impressum">Impressum</a> • <a href="/privacy">Prywatność</a></span>
    </footer>

    <div id="cookie-banner" style="display:none; position:fixed; bottom:0; left:0; right:0; background:rgba(18,26,51,0.98); border-top:1px solid var(--line); padding:16px 24px; z-index:100; font-size:0.9rem; color:var(--muted);">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:16px; max-width:1120px; margin:0 auto;">
        <span>Używamy tylko technicznie niezbędnych plików cookie. <a href="/privacy" style="color:var(--accent);">Dowiedz się więcej</a></span>
        <button id="accept-cookies" style="padding:8px 18px; border-radius:999px; background:linear-gradient(135deg, var(--accent), var(--accent-2)); color:#07111f; border:none; font-weight:700; cursor:pointer; font-size:0.85rem;">Akceptuję</button>
      </div>
    </div>

    <script>
      var cb = document.getElementById('cookie-banner');
      var btn = document.getElementById('accept-cookies');
      if (!localStorage.getItem('cookies_accepted')) { cb.style.display = 'block'; }
      btn && btn.addEventListener('click', function() {
        localStorage.setItem('cookies_accepted', '1');
        cb.style.display = 'none';
      });
    </script>
  </body>
</html>
