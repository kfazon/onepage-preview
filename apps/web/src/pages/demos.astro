---
/**
 * Demos page — stunning showcase of all template types and features.
 */
import { generatePreview } from '@onepage/generator';

export const prerender = false;

const DEMOS = [
  {
    id: 'restaurant',
    name: 'Nova Bistro Zagreb',
    tagline: 'Sezonska kuhinja u srcu grada',
    description: 'Moderna europska kuhinja s lokalnim namirnicama.',
    address: 'Trg bana Josipa Jelačića 12, Zagreb',
    phone: '+385 1 123 4567',
    email: 'info@novabistro.hr',
    hours: 'Pon–Pet 11:00–23:00 · Sub 12:00–24:00 · Ned zatvoreno',
    mapUrl: 'https://maps.google.com/?q=Zagreb+Trg+Josipa+Jelacica',
    template: 'launch-teaser',
    lang: 'hr',
    images: ['https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=800'],
  },
  {
    id: 'agency',
    name: 'Studio Morgen',
    tagline: 'Websites, die wirklich konvertieren',
    description: 'Kleines Studio für performante Landingpages.',
    address: 'Berlin, Deutschland',
    phone: '+49 30 1234 5678',
    email: 'hallo@studiomorgen.de',
    website: 'studiomorgen.de',
    hours: 'Mo–Fr 09:00–18:00',
    template: 'product-spotlight',
    lang: 'de',
    images: ['https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?w=800'],
    services: [
      { name: 'Landing Pages', description: 'Conversion-starke One-Pager.' },
      { name: 'Business Websites', description: 'Saubere Unternehmensseiten.' },
      { name: 'E-Commerce', description: 'Onlineshops mit Zahlungen.' },
    ],
  },
  {
    id: 'event',
    name: 'Berlin Product Meetup #12',
    tagline: 'Monatliches Meetup für Product People',
    description: 'Talks, Networking und ehrliche Gespräche.',
    address: 'Factory Berlin, Rheinsberger Str. 76/77',
    hours: '15. April 2026 · 18:00–21:00',
    mapUrl: 'https://maps.google.com/?q=Factory+Berlin',
    template: 'event-waitlist',
    lang: 'de',
    images: ['https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=800'],
    speakers: [
      { name: 'Anna Keller', role: 'Head of Product' },
      { name: 'Markus Braun', role: 'UX Lead' },
      { name: 'Petra Stein', role: 'Founder' },
    ],
    agenda: [
      { time: '18:00', title: 'Einlass & Networking' },
      { time: '18:30', title: 'Talk: "Von 0 auf PM"' },
      { time: '19:15', title: 'Talk: "Designsysteme"' },
      { time: '20:00', title: 'Panel: "Product-led Growth"' },
      { time: '20:45', title: 'Networking & Drinks' },
    ],
  },
];

const results = DEMOS.map((d) => ({
  ...d,
  result: generatePreview({ ...d }),
}));

const FEATURES = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>`,
    title: 'WhatsApp Button',
    desc: 'Let customers reserve or inquire in one tap — directly from their favorite messaging app.',
    color: '#86efac',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    title: 'Open / Closed Status',
    desc: 'Live opening hours shown on your page — so customers never waste a trip.',
    color: '#67e8f9',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
    title: 'Quick Actions',
    desc: 'Call, email, navigate, or message — all in a floating action bar at the bottom.',
    color: '#7c9cff',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: 'Reviews Section',
    desc: 'Display Google and Yelp reviews right on your page — build trust instantly.',
    color: '#fde68a',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M7 7h.01M7 12h.01M7 17h.01M12 7h.01M12 12h.01M12 17h.01M17 7h.01M17 12h.01M17 17h.01"/></svg>`,
    title: 'QR Code Included',
    desc: 'Every page comes with a print-ready QR code — put it on menus, business cards, or your window.',
    color: '#c4b5fd',
  },
];

const LANGUAGES = [
  { code: 'de', label: 'Deutsch', flag: '🇩🇪' },
  { code: 'es', label: 'Español', flag: '🇪🇸' },
  { code: 'pl', label: 'Polski', flag: '🇵🇱' },
  { code: 'hr', label: 'Hrvatski', flag: '🇭🇷' },
  { code: 'en', label: 'English', flag: '🇬🇧' },
];

const TEMPLATES = [
  { id: 'restaurant', label: 'Launch Teaser', sub: 'Restaurant' },
  { id: 'agency', label: 'Product Spotlight', sub: 'Agency' },
  { id: 'event', label: 'Event Waitlist', sub: 'Meetup' },
];
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Peek — See It In Action</title>
  <style>
    :root {
      --bg: #0b1020;
      --panel: rgba(16, 24, 48, 0.8);
      --panel-strong: #121a33;
      --text: #eef2ff;
      --muted: #a6b0cf;
      --line: rgba(255,255,255,0.1);
      --accent: #7c9cff;
      --accent2: #67e8f9;
      --success: #86efac;
      --shadow: 0 20px 60px rgba(0,0,0,0.35);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, sans-serif;
      background:
        radial-gradient(circle at top, rgba(124,156,255,0.22), transparent 30%),
        radial-gradient(circle at 70% 10%, rgba(103,232,249,0.15), transparent 25%),
        radial-gradient(circle at 20% 80%, rgba(124,156,255,0.1), transparent 25%),
        var(--bg);
      color: var(--text);
      overflow-x: hidden;
    }

    a { color: inherit; text-decoration: none; }
    .container { width: min(1200px, calc(100% - 32px)); margin: 0 auto; }

    /* ─── NAV ─── */
    .nav {
      position: sticky; top: 0;
      backdrop-filter: blur(20px);
      background: rgba(11,16,32,0.75);
      border-bottom: 1px solid var(--line);
      z-index: 100;
    }
    .nav-inner {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 0; gap: 16px;
    }
    .brand { font-weight: 800; font-size: 1.2rem; letter-spacing: 0.02em; }
    .brand span { color: var(--accent2); }
    .nav-links { display: flex; gap: 20px; color: var(--muted); font-size: 0.9rem; }
    .nav-links a:hover { color: var(--text); }

    /* ─── HERO ─── */
    .hero {
      padding: 100px 0 80px;
      text-align: center;
      position: relative;
    }

    .hero-glow {
      position: absolute;
      top: -100px; left: 50%;
      transform: translateX(-50%);
      width: 600px; height: 400px;
      background: radial-gradient(ellipse, rgba(124,156,255,0.25), transparent 70%);
      pointer-events: none;
      animation: pulseGlow 4s ease-in-out infinite;
    }

    @keyframes pulseGlow {
      0%, 100% { opacity: 0.6; transform: translateX(-50%) scale(1); }
      50% { opacity: 1; transform: translateX(-50%) scale(1.1); }
    }

    .hero-badge {
      display: inline-flex; gap: 8px; align-items: center;
      padding: 8px 16px; border-radius: 999px;
      border: 1px solid rgba(134,239,172,0.3);
      background: rgba(134,239,172,0.1);
      color: var(--success); font-size: 0.85rem; font-weight: 600;
      margin-bottom: 28px;
      animation: fadeUp 0.6s ease-out both;
    }

    .hero h1 {
      font-size: clamp(2.8rem, 6vw, 5.5rem);
      line-height: 0.97; letter-spacing: -0.045em;
      margin-bottom: 20px;
      background: linear-gradient(135deg, var(--text) 40%, var(--accent) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: fadeUp 0.6s 0.1s ease-out both;
    }

    .hero p {
      color: var(--muted); font-size: 1.15rem; line-height: 1.7;
      max-width: 60ch; margin: 0 auto 36px;
      animation: fadeUp 0.6s 0.2s ease-out both;
    }

    .hero-actions {
      display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
      animation: fadeUp 0.6s 0.3s ease-out both;
    }

    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      padding: 14px 28px; border-radius: 999px;
      border: none; font-weight: 700; font-size: 1rem;
      transition: all 180ms ease; cursor: pointer;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #07111f; box-shadow: 0 8px 32px rgba(124,156,255,0.4);
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 14px 40px rgba(124,156,255,0.5); }
    .btn-ghost {
      background: rgba(255,255,255,0.05); border: 1px solid var(--line);
      color: var(--text);
    }
    .btn-ghost:hover { background: rgba(255,255,255,0.1); }

    /* ─── TEMPLATE SELECTOR ─── */
    .template-selector {
      display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
      margin: 48px 0 56px;
      animation: fadeUp 0.6s 0.4s ease-out both;
    }

    .tpl-btn {
      padding: 12px 22px; border-radius: 16px;
      background: var(--panel); border: 1px solid var(--line);
      color: var(--muted); font-size: 0.9rem; font-weight: 600;
      cursor: pointer; transition: all 200ms ease;
    }
    .tpl-btn:hover { border-color: var(--accent); color: var(--text); }
    .tpl-btn.active {
      background: rgba(124,156,255,0.15);
      border-color: rgba(124,156,255,0.4);
      color: var(--accent);
    }

    /* ─── BROWSER MOCKUP ─── */
    .browser-frame {
      border-radius: 20px;
      background: var(--panel-strong);
      border: 1px solid rgba(255,255,255,0.12);
      box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.05);
      overflow: hidden;
      transition: transform 400ms ease, box-shadow 400ms ease;
    }
    .browser-frame:hover {
      transform: translateY(-6px) scale(1.005);
      box-shadow: 0 60px 120px rgba(0,0,0,0.6), 0 0 60px rgba(124,156,255,0.1);
    }

    .browser-bar {
      display: flex; align-items: center; gap: 8px;
      padding: 14px 18px;
      background: rgba(255,255,255,0.04);
      border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .dot { width: 11px; height: 11px; border-radius: 50%; }
    .dot-r { background: #ff5f57; }
    .dot-y { background: #ffbd2e; }
    .dot-g { background: #28ca41; }
    .browser-url {
      flex: 1; margin: 0 10px;
      background: rgba(255,255,255,0.06);
      border-radius: 6px; padding: 5px 12px;
      font-size: 0.78rem; color: var(--muted);
      font-family: 'SF Mono', 'Fira Code', monospace;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .browser-iframe {
      width: 100%; border: none; display: block;
      background: #fff;
    }

    /* ─── SECTION REVEALS ─── */
    .reveal {
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.visible { opacity: 1; transform: none; }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }

    /* ─── SECTION HEAD ─── */
    .section { padding: 72px 0; }
    .section-eyebrow {
      display: inline-flex; align-items: center; gap: 6px;
      font-size: 0.8rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--accent); margin-bottom: 14px;
    }
    .section-title {
      font-size: clamp(2rem, 4vw, 3.2rem);
      letter-spacing: -0.04em; line-height: 1.05;
      margin-bottom: 14px;
    }
    .section-sub {
      color: var(--muted); font-size: 1.05rem; max-width: 60ch; line-height: 1.7;
    }

    /* ─── DEMO SECTIONS ─── */
    .demo-section { padding: 80px 0; }
    .demo-section + .demo-section { padding-top: 0; }

    .demo-layout {
      display: grid; grid-template-columns: 1fr 1fr; gap: 56px;
      align-items: center;
    }
    .demo-layout.reverse { direction: rtl; }
    .demo-layout.reverse > * { direction: ltr; }

    .demo-info { }
    .demo-tag {
      display: inline-block;
      padding: 5px 14px; border-radius: 999px;
      background: rgba(124,156,255,0.12);
      border: 1px solid rgba(124,156,255,0.25);
      color: var(--accent); font-size: 0.8rem; font-weight: 700;
      margin-bottom: 18px;
    }
    .demo-info h2 {
      font-size: 2rem; letter-spacing: -0.03em; margin-bottom: 12px;
    }
    .demo-info p { color: var(--muted); line-height: 1.7; margin-bottom: 24px; max-width: 50ch; }

    .mini-features {
      display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 28px;
    }
    .mini-feat {
      display: flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 8px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      font-size: 0.82rem; color: var(--muted);
    }
    .mini-feat svg { color: var(--success); flex-shrink: 0; }

    .browser-wrap { }
    .browser-wrap.desktop .browser-iframe { height: 520px; }
    .browser-wrap.mobile {
      max-width: 340px;
      margin: 0 auto;
    }
    .browser-wrap.mobile .browser-iframe { height: 620px; }

    /* ─── FEATURES ─── */
    .features-section { padding: 80px 0; }
    .features-header { text-align: center; margin-bottom: 56px; }
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
    }
    .feature-card {
      padding: 28px 22px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 24px;
      transition: all 250ms ease;
    }
    .feature-card:hover {
      border-color: rgba(124,156,255,0.35);
      transform: translateY(-4px);
      box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }
    .feature-icon {
      width: 52px; height: 52px; border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px;
    }
    .feature-card h3 { font-size: 1.05rem; margin-bottom: 8px; }
    .feature-card p { color: var(--muted); font-size: 0.88rem; line-height: 1.6; }

    /* ─── LANGUAGES ─── */
    .lang-section { padding: 72px 0; text-align: center; }
    .lang-grid { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 36px; }
    .lang-card {
      display: flex; flex-direction: column; align-items: center; gap: 10px;
      padding: 24px 28px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 20px;
      min-width: 120px;
      transition: all 220ms ease;
    }
    .lang-card:hover {
      border-color: rgba(124,156,255,0.3);
      transform: translateY(-3px);
    }
    .lang-flag { font-size: 2.6rem; line-height: 1; }
    .lang-label { font-weight: 600; font-size: 0.9rem; color: var(--muted); }
    .lang-code { font-size: 0.75rem; color: var(--accent); font-weight: 700; }

    /* ─── MOBILE DEMO ─── */
    .mobile-section { padding: 80px 0; }
    .mobile-header { text-align: center; margin-bottom: 48px; }
    .mobile-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 20px; align-items: end;
    }
    .mobile-col { display: flex; flex-direction: column; gap: 16px; align-items: center; }

    /* ─── CTA BAND ─── */
    .cta-band {
      padding: 80px 0;
      text-align: center;
      background: linear-gradient(135deg, rgba(124,156,255,0.18), rgba(103,232,249,0.1));
      border-top: 1px solid rgba(255,255,255,0.08);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }
    .cta-band h2 {
      font-size: clamp(1.8rem, 4vw, 3rem);
      letter-spacing: -0.04em; margin-bottom: 14px;
    }
    .cta-band p { color: var(--muted); font-size: 1.05rem; margin-bottom: 28px; }

    /* ─── FOOTER ─── */
    footer {
      padding: 40px 0;
      text-align: center; color: var(--muted); font-size: 0.85rem;
      border-top: 1px solid var(--line);
    }
    footer a { color: var(--accent); }

    /* ─── ANIMATIONS ─── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: none; }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .demo-layout { grid-template-columns: 1fr; gap: 32px; }
      .demo-layout.reverse { direction: ltr; }
      .mobile-grid { grid-template-columns: 1fr; }
      .features-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 600px) {
      .features-grid { grid-template-columns: 1fr; }
      .hero { padding: 60px 0 48px; }
    }

    /* Template panels */
    .template-panel { display: none; }
    .template-panel.active { display: block; }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="nav">
    <div class="container">
      <div class="nav-inner">
        <a href="/" class="brand">peek<span>.</span></a>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/demos">Demos</a>
          <a href="/vs">vs Competitors</a>
          <a href="/api/preview?name=Demo">API</a>
        </div>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="container">
      <div class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/></svg>
        Live Preview Generator
      </div>
      <h1>See Peek<br>in Action</h1>
      <p>Three powerful templates. Five smart features. One free preview delivered to your inbox — no signup required.</p>
      <div class="hero-actions">
        <a href="#preview" class="btn btn-primary">Get Your Free Preview →</a>
        <a href="#features" class="btn btn-ghost">Explore Features</a>
      </div>

      <!-- TEMPLATE SELECTOR -->
      <div class="template-selector" id="preview">
        {TEMPLATES.map((t) => (
          <button class="tpl-btn active" data-tpl={t.id} onclick="switchTemplate(this)">
            {t.label}
            <span style="color:var(--muted);font-weight:400">— {t.sub}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- MAIN PREVIEW AREA -->
  <section style="padding: 0 0 80px">
    <div class="container">
      {results.map((demo, i) => (
        <div class="template-panel reveal" id={`panel-${demo.id}`} data-index={i}>
          <div class="browser-frame">
            <div class="browser-bar">
              <div class="dot dot-r"></div>
              <div class="dot dot-y"></div>
              <div class="dot dot-g"></div>
              <div class="browser-url">peek.page/{demo.id.toLowerCase()}-{demo.lang}</div>
            </div>
            <iframe
              class="browser-iframe"
              style="height:560px"
              srcdoc={demo.result.html}
              title={`Preview: ${demo.name}`}
              loading="lazy"
            />
          </div>
          <div style="text-align:center;margin-top:16px;color:var(--muted);font-size:0.85rem">
            {demo.template} · {demo.lang.toUpperCase()} · {demo.name}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURES -->
  <section class="features-section section" id="features">
    <div class="container">
      <div class="features-header reveal">
        <div class="section-eyebrow">✦ What You Get</div>
        <h2 class="section-title">Five Features That<br/>Actually Convert</h2>
        <p class="section-sub">Every Peek page is built to turn visitors into customers — not just look good.</p>
      </div>
      <div class="features-grid">
        {FEATURES.map((f, i) => (
          <div class={`feature-card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class="feature-icon" style={`background: ${f.color}18; color: ${f.color}`}>
              <Fragment set:html={f.icon} />
            </div>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LAUNCH TEASER DEMO -->
  <section class="demo-section section" id="launch">
    <div class="container">
      <div class="demo-layout reveal">
        <div class="demo-info">
          <div class="demo-tag">Launch Teaser</div>
          <h2>Perfect for New<br/>Businesses</h2>
          <p>Launch Teaser is built for restaurants, salons, consultancies, and anyone who needs a professional online presence — fast. Clean hero, social proof, and a clear CTA.</p>
