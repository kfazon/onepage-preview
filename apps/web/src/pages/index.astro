---
const title = 'Peek — Free one-page previews for businesses';
const stats = [
  { value: '60 sec', label: 'to claim a preview' },
  { value: '1 page', label: 'built for mobile-first conversion' },
  { value: '0€', label: 'to see your first preview' }
];

const steps = [
  {
    title: 'We find public business info',
    body: 'Name, hours, location, photos, and contact details from public sources — never private data.'
  },
  {
    title: 'We generate a polished preview',
    body: 'A clean one-page site with hero, services, map, social proof, and a clear contact CTA.'
  },
  {
    title: 'You claim, edit, or upgrade',
    body: 'Keep the free preview, connect a domain, or let us take it live with hosting and support.'
  }
];

const templates = [
  {
    name: 'Launch teaser',
    useCase: 'New businesses, consultants, small brands',
    features: ['Hero + CTA', 'Benefits grid', 'Social proof', 'Sticky CTA']
  },
  {
    name: 'Product spotlight',
    useCase: 'Single-offer businesses and service packages',
    features: ['Feature grid', 'Comparison section', 'FAQ', 'Lead capture']
  },
  {
    name: 'Event waitlist',
    useCase: 'Events, workshops, pop-ups, openings',
    features: ['Agenda', 'Speaker cards', 'Map embed', 'Waitlist form']
  }
];

const pricing = [
  {
    tier: 'Preview',
    price: '0€',
    description: 'Free proof-of-value page',
    points: ['Preview URL', 'Business info + CTA', '1 revision', 'Opt-out anytime']
  },
  {
    tier: 'Go Live',
    price: '29€/mo',
    description: 'The simplest production plan',
    points: ['Custom domain', 'No preview branding', 'Analytics', 'Managed contact form']
  },
  {
    tier: 'Growth',
    price: '79€/mo',
    description: 'For businesses that need discoverability',
    points: ['SEO basics', 'Google Business sync', 'Social links', 'Priority edits']
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Peek auto-generates fast one-page previews for businesses without a website. Claim it free, then upgrade when you're ready." />
    <title>{title}</title>
    <style>
      :root {
        --bg: #0b1020;
        --panel: rgba(16, 24, 48, 0.8);
        --panel-strong: #121a33;
        --text: #eef2ff;
        --muted: #a6b0cf;
        --line: rgba(255,255,255,0.1);
        --accent: #7c9cff;
        --accent-2: #67e8f9;
        --success: #86efac;
        --shadow: 0 20px 60px rgba(0,0,0,0.35);
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top, rgba(124,156,255,0.18), transparent 25%),
          radial-gradient(circle at right, rgba(103,232,249,0.12), transparent 20%),
          var(--bg);
        color: var(--text);
      }

      a { color: inherit; text-decoration: none; }
      .container { width: min(1120px, calc(100% - 32px)); margin: 0 auto; }

      .nav {
        position: sticky;
        top: 0;
        backdrop-filter: blur(16px);
        background: rgba(11,16,32,0.7);
        border-bottom: 1px solid var(--line);
        z-index: 10;
      }

      .nav-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 0;
        gap: 16px;
      }

      .brand { font-weight: 800; letter-spacing: 0.02em; }
      .brand span { color: var(--accent-2); }

      .nav-links {
        display: flex;
        gap: 18px;
        color: var(--muted);
        font-size: 0.95rem;
      }
      .lang-switcher { display: flex; gap: 6px; margin-left: 16px; padding-left: 16px; border-left: 1px solid var(--line); }
      .lang-btn { padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: 600; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.1); color: var(--muted); text-decoration: none; transition: 150ms; }
      .lang-btn:hover { background: rgba(255,255,255,0.1); color: var(--text); }
      .lang-btn.active { background: rgba(124,156,255,0.15); border-color: rgba(124,156,255,0.3); color: var(--accent); }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 14px 20px;
        border-radius: 999px;
        border: 1px solid transparent;
        font-weight: 700;
        transition: 180ms ease;
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        color: #07111f;
        box-shadow: var(--shadow);
      }

      .btn-primary:hover { transform: translateY(-1px); }
      .btn-secondary {
        border-color: var(--line);
        background: rgba(255,255,255,0.02);
      }

      .hero {
        padding: 72px 0 40px;
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 32px;
        align-items: center;
      }

      .eyebrow {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        padding: 8px 12px;
        border: 1px solid rgba(134,239,172,0.25);
        border-radius: 999px;
        color: var(--success);
        background: rgba(134,239,172,0.08);
        font-size: 0.9rem;
        margin-bottom: 20px;
      }

      h1 {
        margin: 0 0 16px;
        font-size: clamp(2.6rem, 5vw, 4.8rem);
        line-height: 0.98;
        letter-spacing: -0.04em;
      }

      .hero p {
        margin: 0 0 28px;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.7;
        max-width: 62ch;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 28px;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
      }

      .stat, .card {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 24px;
        box-shadow: var(--shadow);
      }

      .stat {
        padding: 18px;
      }

      .stat strong {
        display: block;
        font-size: 1.2rem;
        margin-bottom: 6px;
      }

      .stat span { color: var(--muted); font-size: 0.92rem; }

      .preview-shell {
        padding: 18px;
      }

      .browser-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,0.25);
      }

      .preview-body {
        border-radius: 20px;
        background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
        border: 1px solid rgba(255,255,255,0.08);
        overflow: hidden;
      }

      .preview-hero {
        padding: 22px;
        background: linear-gradient(135deg, rgba(124,156,255,0.24), rgba(103,232,249,0.14));
      }

      .preview-hero small { color: var(--muted); }
      .preview-hero h3 { margin: 8px 0; font-size: 1.6rem; }
      .preview-hero p { margin: 0; color: #dce4ff; }

      .preview-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 12px;
        padding: 16px;
      }

      .mini-card {
        padding: 14px;
        border-radius: 16px;
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.06);
      }

      section {
        padding: 36px 0;
      }

      .section-head {
        margin-bottom: 20px;
      }

      .section-head h2 {
        margin: 0 0 8px;
        font-size: clamp(1.8rem, 3vw, 2.6rem);
      }

      .section-head p {
        margin: 0;
        color: var(--muted);
        max-width: 70ch;
      }

      .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }

      .grid-3 .card, .grid-pricing .card { padding: 22px; }
      .card h3 { margin: 0 0 10px; }
      .card p, .card li { color: var(--muted); line-height: 1.65; }
      .card ul { padding-left: 18px; margin: 12px 0 0; }

      .grid-pricing {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
      }

      .price {
        font-size: 2rem;
        font-weight: 800;
        margin: 10px 0;
      }

      .highlight {
        position: relative;
        overflow: hidden;
      }

      .highlight::after {
        content: 'Popular';
        position: absolute;
        top: 14px;
        right: -36px;
        background: var(--accent-2);
        color: #041018;
        padding: 6px 42px;
        transform: rotate(35deg);
        font-size: 0.8rem;
        font-weight: 800;
      }

      .banner {
        padding: 22px;
        border-radius: 24px;
        border: 1px solid var(--line);
        background: linear-gradient(135deg, rgba(124,156,255,0.16), rgba(103,232,249,0.12));
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      footer {
        padding: 28px 0 48px;
        color: var(--muted);
        font-size: 0.95rem;
      }

      @media (max-width: 920px) {
        .hero,
        .preview-grid,
        .grid-3,
        .grid-pricing,
        .stats {
          grid-template-columns: 1fr;
        }

        .nav-inner,
        .banner {
          flex-direction: column;
          align-items: flex-start;
        }

        .nav-links { flex-wrap: wrap; }
      }
    </style>
  </head>
  <body>
    <header class="nav">
      <div class="container nav-inner">
        <a class="brand" href="#top">Peek<span>.</span></a>
        <nav class="nav-links">
          <a href="#how-it-works">How it works</a>
          <a href="#templates">Templates</a>
          <a href="#pricing">Pricing</a>
        </nav>
        <div class="lang-switcher">
          <a class="lang-btn" href="/">EN</a>
          <a class="lang-btn" href="/de/">DE</a>
          <a class="lang-btn" href="/es/">ES</a>
          <a class="lang-btn" href="/pl/">PL</a>
        </div>
      </div>
    </header>

    <main id="top" class="container">
      <section class="hero">
        <div>
          <div class="eyebrow">Free preview • Built from public business info • Claim in 60 seconds</div>
          <h1>We build the first version of your business website before you hire us.</h1>
          <p>
            Peek auto-generates clean one-page previews for businesses that still rely on Instagram, Google Maps,
            or word-of-mouth. See the page first, then decide whether to claim it, edit it, or upgrade it.
          </p>
          <div class="cta-row">
            <a class="btn btn-primary" href="#pricing">See pricing</a>
            <a class="btn btn-secondary" href="#templates">View template system</a>
          </div>
          <div class="stats">
            {stats.map((item) => (
              <div class="stat">
                <strong>{item.value}</strong>
                <span>{item.label}</span>
              </div>
            ))}
          </div>
        </div>

        <aside class="card preview-shell" aria-label="Preview example">
          <div class="browser-bar">
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
          </div>
          <div class="preview-body">
            <div class="preview-hero">
              <small>Preview URL • mobile-ready • fast-loading</small>
              <h3>Nova Bistro Zagreb</h3>
              <p>Seasonal lunch menu, reservations, opening hours, and direct contact — all above the fold.</p>
            </div>
            <div class="preview-grid">
              <div class="mini-card">
                <strong>What visitors see</strong>
                <p>Hero, menu highlights, map, social proof, and one clear contact CTA.</p>
              </div>
              <div class="mini-card">
                <strong>What owner gets</strong>
                <p>Claim link, editable content, upgrade path, and simple lead capture.</p>
              </div>
            </div>
          </div>
        </aside>
      </section>

      <section id="how-it-works">
        <div class="section-head">
          <h2>How Peek works</h2>
          <p>
            The workflow is simple on purpose: build visible value first, then convert the right businesses into paid hosting and support.
          </p>
        </div>
        <div class="grid-3">
          {steps.map((step, index) => (
            <article class="card">
              <small>Step {index + 1}</small>
              <h3>{step.title}</h3>
              <p>{step.body}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="templates">
        <div class="section-head">
          <h2>Template system for fast preview generation</h2>
          <p>
            We start narrow with reusable templates that can fit multiple niches without rebuilding from zero every time.
          </p>
        </div>
        <div class="grid-3">
          {templates.map((template) => (
            <article class="card">
              <h3>{template.name}</h3>
              <p><strong>Best for:</strong> {template.useCase}</p>
              <ul>
                {template.features.map((feature) => <li>{feature}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section id="pricing">
        <div class="section-head">
          <h2>Simple pricing path</h2>
          <p>
            Free preview as the lead magnet. Low-friction production plan when the owner wants a real domain and support.
          </p>
        </div>
        <div class="grid-pricing">
          {pricing.map((plan, index) => (
            <article class:list={["card", index === 1 && "highlight"]}>
              <small>{plan.tier}</small>
              <div class="price">{plan.price}</div>
              <p>{plan.description}</p>
              <ul>
                {plan.points.map((point) => <li>{point}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section>
        <div class="banner">
          <div>
            <h2 style="margin:0 0 8px;">Built for ethical outreach</h2>
            <p style="margin:0; color:var(--muted); max-width:64ch;">
              Every preview must include a clear claim flow, opt-out path, and transparent use of public business data.
            </p>
          </div>
          <a class="btn btn-primary" href="mailto:hello@peek.example">Request first niche rollout</a>
        </div>
      </section>
    </main>

    <footer class="container">
      Peek • One-page preview platform for small businesses • Free preview first, go-live second.
    </footer>
  </body>
</html>
