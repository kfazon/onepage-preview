---
export const prerender = false;

export async function getProps({ params, request }) {
  const id = params.id || '';
  let pageUrl = '';
  let businessName = 'Your Business';

  try {
    // ID is base64-encoded JSON: { pageUrl, name }
    const decoded = JSON.parse(atob(id));
    pageUrl = decoded.pageUrl || '';
    businessName = decoded.name || businessName;
  } catch {
    // Fallback: treat ID as direct URL or name
    pageUrl = id.startsWith('http') ? id : `https://peek-preview.pages.dev/preview/${id}`;
  }

  // Encode for QR
  const qrUrl = pageUrl || 'https://peek-preview.pages.dev';
  const qrSrc = `https://api.qrserver.com/v1/create-qr-code/?size=300x300&data=${encodeURIComponent(qrUrl)}`;

  return { id, pageUrl: qrUrl, businessName, qrSrc };
}
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`Download QR — ${businessName} | Peek`} />
  <meta property="og:description" content={`Download the QR code for ${businessName}`} />
  <meta property="og:image" content={qrSrc} />
  <meta name="twitter:card" content="summary_large_image" />
  <title>Download QR — {businessName}</title>
  <style>
    :root {
      --bg: #0b1020;
      --panel: rgba(16, 24, 48, 0.8);
      --text: #eef2ff;
      --muted: #a6b0cf;
      --line: rgba(255,255,255,0.1);
      --accent: #7c9cff;
      --accent2: #67e8f9;
      --success: #86efac;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, sans-serif;
      background: radial-gradient(circle at top, rgba(124,156,255,0.18), transparent 35%), var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .container { width: min(520px, calc(100% - 32px)); margin: 0 auto; }

    header {
      padding: 32px 0 0;
      text-align: center;
    }
    .brand { font-weight: 800; font-size: 1.3rem; letter-spacing: 0.02em; }
    .brand span { color: var(--accent2); }

    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 0;
      gap: 28px;
    }

    .qr-card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 28px;
      padding: 40px;
      text-align: center;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 24px 80px rgba(0,0,0,0.4);
    }

    .qr-label {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 20px;
    }

    .qr-img-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 24px;
    }

    .qr-img {
      width: 300px;
      height: 300px;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    .business-name {
      font-family: Fraunces, Georgia, serif;
      font-size: 1.5rem;
      letter-spacing: -0.03em;
      margin-bottom: 6px;
    }

    .qr-url {
      font-size: 0.85rem;
      color: var(--muted);
      word-break: break-all;
      margin-bottom: 28px;
      background: rgba(255,255,255,0.04);
      padding: 8px 14px;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.06);
    }

    .btn-row {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 14px 24px;
      border-radius: 999px;
      border: 1px solid transparent;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 180ms ease;
      text-decoration: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      color: #07111f;
      box-shadow: 0 8px 28px rgba(124,156,255,0.35);
    }
    .btn-primary:hover { transform: translateY(-1px); text-decoration: none; }
    .btn-ghost {
      background: rgba(255,255,255,0.05);
      border-color: var(--line);
      color: var(--text);
    }
    .btn-ghost:hover { background: rgba(255,255,255,0.1); text-decoration: none; }

    .divider {
      width: 100%;
      max-width: 420px;
      height: 1px;
      background: var(--line);
    }

    .cta-section {
      text-align: center;
      padding: 0 0 16px;
    }
    .cta-section h2 {
      font-size: 1.6rem;
      letter-spacing: -0.03em;
      margin-bottom: 8px;
    }
    .cta-section p {
      color: var(--muted);
      font-size: 0.95rem;
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <header>
    <div class="container">
      <a class="brand" href="/">peek<span>.</span></a>
    </div>
  </header>

  <main>
    <div class="qr-card">
      <p class="qr-label">Scan to visit</p>
      <div class="qr-img-wrap">
        <img class="qr-img" src={qrSrc} alt="QR Code for {businessName}" id="qr-img" />
      </div>
      <h1 class="business-name">{businessName}</h1>
      <p class="qr-url">{pageUrl}</p>
      <div class="btn-row">
        <button class="btn btn-primary" onclick="downloadQR()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Download PNG
        </button>
        <button class="btn btn-ghost" onclick="printQR()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Print
        </button>
      </div>
    </div>

    <div class="divider"></div>

    <div class="cta-section">
      <h2>Get your own page at Peek</h2>
      <p>Beautiful one-page sites for businesses — from €149/month</p>
      <a class="btn btn-primary" href="/upgrade">See pricing →</a>
    </div>
  </main>

  <script>
    function downloadQR() {
      var img = document.getElementById('qr-img');
      var url = img.src;
      var canvas = document.createElement('canvas');
      var ctx = canvas.getContext('2d');
      var i = new Image();
      i.crossOrigin = 'Anonymous';
      i.onload = function() {
        canvas.width = i.width;
        canvas.height = i.height;
        ctx.fillStyle = '#ffffff';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(i, 0, 0);
        var a = document.createElement('a');
        a.download = 'qr-code.png';
        a.href = canvas.toDataURL('image/png');
        a.click();
      };
      i.onerror = function() {
        // Fallback: open image in new tab for browser save
        window.open(url, '_blank');
      };
      i.src = url;
    }

    function printQR() {
      var img = document.getElementById('qr-img');
      var win = window.open('', '_blank');
      win.document.write('<html><head><title>Print QR Code</title></head><body style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;margin:0;background:#fff;">' +
        '<img src="' + img.src + '" style="width:300px;height:300px;" />' +
        '<p style="margin-top:16px;font-family:sans-serif;color:#333;">Scan to visit</p>' +
        '<script>window.onload=function(){window.print();window.close();}<\/script>' +
        '</body></html>');
      win.document.close();
    }
  </script>
</body>
</html>